<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>TruthEngine // Neural Verification</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>

    <div id="loader">
        <div class="spinner"></div>
        <p style="margin-top: 20px; color: var(--primary); letter-spacing: 5px; font-size: 0.7rem;">INITIALIZING CORE_SYSTEMS...</p>
    </div>

    <div class="container">
        <nav class="nav-tabs">
            <span class="nav-link active" onclick="showTab('detector')">Detector</span>
            <span class="nav-link" onclick="showTab('team')">Team</span>
            <span class="nav-link" onclick="showTab('docs')">Documentation</span>
        </nav>

        <div id="detector" class="content-section active">
    <h1>TruthEngine</h1>
    <p class="subtitle">Machine-powered News Verification</p>

    <div class="examples">
        <a href="/?sample=real"><button class="btn-sample" type="button">✦ Real Insight</button></a>
        <a href="/?sample=fake"><button class="btn-sample" type="button">✦ Viral Hoax</button></a>
    </div>

    <form method="POST" action="/predict">
        <textarea id="news" name="news_input" placeholder="Paste article content here..." required><%= locals.news_input %></textarea>
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
            <span class="meta" style="color: #4b5563;">Analysis: Logistic Regression · TF-IDF</span>
            <span class="meta" style="color: #4b5563;">Words: <%= locals.word_count %></span>
        </div>

        <button type="submit" class="analyze-btn">RUN DIAGNOSTICS</button>
    </form>

    <% if (locals.warning) { %>
        <div class="warning" style="color: #ffcc00; text-align: center; margin-top: 15px; font-size: 0.9rem;">
            ◈ <%= warning %>
        </div>
    <% } %>

    <% if (locals.result_label) { %>
        <div class="result <%= result_class %>">
            <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px;">Classification Outcome</span>
            <h2 style="margin: 10px 0;"><%= result_label %></h2>
            <div style="font-size: 0.9rem; margin-bottom: 5px;">Confidence Score: <%= confidence_percent.toFixed(2) %>%</div>
            
            <div class="progress-wrap">
                <div class="progress" style="width: <%= confidence_percent %>%"></div>
            </div>
        </div>
    <% } %>
</div>

        <div id="team" class="content-section">
            <h2 style="text-align: center; color: var(--primary);">Development Team</h2>
            <div class="team-grid">
                <div class="team-card"><h3>Krish</h3><p>UI/UX + Backend Engineer</p></div>
                <div class="team-card"><h3>Shaurya</h3><p>AI Architect</p></div>
                <div class="team-card"><h3>Harsh</h3><p>Documentation and Data Science</p></div>
            </div>
        </div>

        <div id="docs" class="content-section">
            <div id="markdown-body" class="docs-content">
                </div>
        </div>

        <footer>Designed for Chandigarh University AI Applications Lab Project · 2026</footer>
    </div>

    <script>
        // Tab Logic
        function showTab(tabId) {
            document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            event.target.classList.add('active');
        }

        // Markdown Content (You can edit this easily)
        const docsMarkdown = `
## Project Overview
TruthEngine is a **Logistic Regression** based analysis tool. 

### How it works:
1. **Vectorization**: Uses \`TF-IDF\` to turn words into math.
2. **Classification**: Evaluates patterns against a trained dataset of 40k+ articles.
3. **Deployment**: Express.js frontend with a Python ML bridge.

> Note: High confidence (>90%) suggests strong structural alignment with known fake news patterns.
        `;
        document.getElementById('markdown-body').innerHTML = marked.parse(docsMarkdown);

        // Loader Logic
        window.addEventListener('load', () => {
            const loader = document.getElementById('loader');
            setTimeout(() => {
                loader.style.opacity = '0';
                setTimeout(() => loader.style.display = 'none', 500);
            }, 1500); // 1.5 second "fake" load for style
        });
    </script>
</body>
</html>